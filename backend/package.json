{
  "name": "samajob-backend",
  "version": "1.0.0",
  "description": "API REST SamaJob – Plateforme de micro-missions sénégalaise",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "postinstall": "prisma generate",
