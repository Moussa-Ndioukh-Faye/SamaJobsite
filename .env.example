# ──────────────────────────────────────────────────────────────────────────────
# SamaJob – Variables d'environnement Docker
# Copier ce fichier en .env et remplir les valeurs avant de lancer docker-compose
# ──────────────────────────────────────────────────────────────────────────────

# Mot de passe PostgreSQL (utilisé par le conteneur db et le backend)
POSTGRES_PASSWORD=changez_ce_mot_de_passe_fort

# Clé secrète JWT — générez une clé aléatoire avec :
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=remplacez_par_une_cle_aleatoire_de_96_caracteres_hex

# Durée de validité du token JWT
JWT_EXPIRES_IN=7d

# URL d'accès publique au site (pour les en-têtes CORS du backend)
FRONTEND_URL=http://localhost

# Port exposé sur l'hôte (80 par défaut, utilisez 8080 si 80 est pris)
APP_PORT=80
